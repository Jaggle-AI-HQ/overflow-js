{
  "name": "@jaggle-ai/overflow-nextjs",
  "version": "0.1.0",
  "description": "Jaggle Overflow SDK for Next.js applications",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/client.tsx --format cjs,esm --dts --clean --external react --external next --external @jaggle-ai/overflow-browser --external @jaggle-ai/overflow-react",
    "dev": "tsup src/index.ts src/client.tsx --format cjs,esm --dts --watch --external react --external next --external @jaggle-ai/overflow-browser --external @jaggle-ai/overflow-react",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=17.0.0",
    "@jaggle-ai/overflow-browser": ">=0.1.0",
    "@jaggle-ai/overflow-react": ">=0.1.0"
  },
  "devDependencies": {
    "@jaggle-ai/overflow-browser": "*",
    "@jaggle-ai/overflow-react": "*",
    "@types/react": "^19.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "overflow",
    "error-tracking",
    "nextjs",
    "server-components"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jaggle-AI-HQ/overflow-js",
    "directory": "sdks/js/packages/nextjs"
  }
}
