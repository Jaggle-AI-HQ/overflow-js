{
  "name": "@jaggle-ai/overflow-react",
  "version": "0.1.1",
  "description": "Jaggle Overflow SDK for React applications",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --external react --external @jaggle-ai/overflow-browser",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external react --external @jaggle-ai/overflow-browser",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "@jaggle-ai/overflow-browser": ">=0.2.0"
  },
  "devDependencies": {
    "@jaggle-ai/overflow-browser": "*",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "overflow",
    "error-tracking",
    "react",
    "error-boundary"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jaggle-AI-HQ/overflow-js",
    "directory": "sdks/js/packages/react"
  }
}
